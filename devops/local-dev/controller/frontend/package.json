    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.0.0",
    "lefthook": "^1.13.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "overrides": {
    "picomatch": "^4.0.4",

{
  "name": "controller-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "cp /env/.env . && vite",
    "build": "cp /env/.env . && tsc && vite build",
